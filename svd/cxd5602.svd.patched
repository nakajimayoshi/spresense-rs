                </enumeratedValue>
                <enumeratedValue>
                  <name>RUN</name>
                  <description>Normal Descriptor Set and Run</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>STOP</name>
