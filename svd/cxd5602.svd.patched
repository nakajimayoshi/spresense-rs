                  <value>9</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>11bit</name>
                  <description>11bit data</description>
                  <value>10</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>12bit</name>
                  <description>12bit data</description>
                  <value>11</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>13bit</name>
                  <description>13bit data</description>
                  <value>12</value>
                </enumeratedValue>
                <enumeratedValue>
