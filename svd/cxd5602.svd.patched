    </peripheral>
    <peripheral>
      <name>SCU_ADCIF</name>
      <description>SCU ADC Interface — LPADC/HPADC control and per-channel FIFO read ports. CPU APB read of LPADC_FIFO(n) dequeues one sample from the hardware FIFO of LPADC channel n (no iSoP needed). UM §3.21.12.1; Mirror base 0x0418DC00.</description>
      <baseAddress>0x0418DC00</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <dim>4</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>LPADC_FIFO[%s]</name>
          <description>LPADC ch%s FIFO Read Port — dequeue one 10-bit sample (MSB-aligned in 16-bit word; DATA = bits[15:6] as 0..=1023)</description>
          <addressOffset>0x0</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATA</name>
              <description>10-bit ADC result, right-justified (raw bits[15:6] of MSB-aligned word; multiply by VDDA_LPADC/1023 for volts)</description>
              <bitOffset>6</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <dim>2</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>HPADC_FIFO[%s]</name>
          <description>HPADC ch%s FIFO Read Port (SEN_AIN0/1, Arduino A4/A5)</description>
          <addressOffset>0x80</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DATA</name>
              <description>10-bit HPADC sample, right-justified</description>
              <bitOffset>6</bitOffset>
              <bitWidth>10</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>LPADC_A0</name>
          <description>LPADC Enable Control — LV_ADC_EN (UM Table ADC-106)</description>
          <addressOffset>0x200</addressOffset>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LV_ADC_EN</name>
              <description>LPADC enable: 0=standby, 1=active</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>LPADC_A1</name>
          <description>LPADC Channel Switching Control (UM Table ADC-107)</description>
          <addressOffset>0x204</addressOffset>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LV_CH_SEL_INV</name>
              <description>ADCH selector for GNSS (active channel: 0=CH0 … 3=CH3)</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>LV_CH_SEL_MODE</name>
              <description>Channel switching mode</description>
              <bitOffset>0</bitOffset>
