          <modifiedWriteValues>oneToClear</modifiedWriteValues>
        </register>
        <register>
          <name>ADDRESS_DESCRIPTOR_START</name>
          <description>Descriptor Address Set Register</description>
          <addressOffset>0x8</addressOffset>
